# TELEGRAM & LLM CONFIGURATION
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
CEO_CHAT_ID=your_telegram_chat_id_here

OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LLM Configuration
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4-turbo-preview
FALLBACK_LLM_MODEL=gpt-3.5-turbo

# STRIPE (Financial)
STRIPE_API_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# GITHUB (Code Repository)
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_ORG=your_github_org_here

# CRYPTO TREASURY (Optional)
# ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/your_project_id
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# BASE_RPC_URL=https://mainnet.base.org

# Wallet addresses (for monitoring)
# ETH_TREASURY_WALLET=0x...
# SOL_TREASURY_WALLET=...
# BASE_TREASURY_WALLET=0x...

# DATABASE
DATABASE_URL=postgresql://ord:ord@localhost:5432/ord
REDIS_URL=redis://localhost:6379
CHROMA_URL=http://localhost:8001

# SECURITY
ENCRYPTION_KEY=your_32_byte_encryption_key_here
JWT_SECRET=your_jwt_secret_here

# ORD CONFIGURATION
ORD_ENVIRONMENT=development
ORD_DEMO_MODE=false
ORD_LOG_LEVEL=INFO

# Budget Limits
MAX_TOKENS_PER_RESPONSE=2000
WEEKLY_TOKEN_BUDGET=1000000
MAX_REFLECTION_CYCLES=3
MAX_TOOL_CREATIONS_PER_WEEK=5

# FEATURE FLAGS
ENABLE_TELEGRAM=true
ENABLE_VOICE=true
ENABLE_STRIPE=true
ENABLE_GITHUB=true
ENABLE_CRYPTO=false

# EXTERNAL SERVICES
VERCEL_TOKEN=your_vercel_token_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_key_here
